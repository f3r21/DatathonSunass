# === Backend LLM ===
# Valores validos: "ollama" | "openai" | "auto"
# - ollama: usar exclusivamente el servidor local (3060 remota o M2).
# - openai: usar exclusivamente OpenAI (requiere OPENAI_API_KEY).
# - auto: intentar ollama primero, caer a openai si no responde.
LLM_BACKEND=auto

# === Ollama ===
# Cuando la 3060 remota esta disponible, apuntar a su IP via tunel/VPN.
# Local (M2 fallback): http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_MODEL_FALLBACK=llama3.2:3b-instruct-q4_K_M

# === OpenAI (fallback de red) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === RAG ===
RAG_CORPUS_DIR=./docs_sunass
RAG_INDEX_DIR=./chroma_db
RAG_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5

# === Datos (rutas locales, no se comitean) ===
DATA_DIR=../datos
INTERRUPCIONES_PATH=../datos/interrupciones/historico_interrupciones_limpio.dta
MOREA_PARQUET_PATH=../datos/morea/datos_morea.parquet
MOREA_ESTACIONES_PATH=../datos/morea/ubicacion_estaciones_MOREA.xlsx

# === Dashboard ===
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
