# Rutas a los datasets oficiales del Datathon SUNASS 2026.
# Forward slashes incluso en Windows (Polars/pyreadstat los normalizan).
# Si pones rutas relativas, se resuelven contra este .env (no contra cwd),
# por lo que funcionan desde la app, scripts/ o reports/ por igual.

INTERRUPCIONES_PATH=../datos/interrupciones/historico_interrupciones_limpio.dta
MOREA_PARQUET_PATH=../datos/morea/datos_morea.parquet
MOREA_ESTACIONES_PATH=../datos/morea/ubicacion_estaciones_MOREA.xlsx

# (Opcional) puerto/host de Streamlit; el default ya esta en .streamlit/config.toml
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0
